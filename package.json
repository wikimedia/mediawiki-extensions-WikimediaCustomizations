{
	"name": "WikimediaCustomizations",
	"private": true,
	"scripts": {
		"api-testing": "mocha --timeout 0 --recursive tests/api-testing",
		"lint": "npm run lint:i18n && npm run lint:scripts && npm run lint:scripts:tests && npm run lint:styles",
		"lint:i18n": "banana-checker i18n/ i18n/attribution/",
		"lint:scripts": "eslint --cache --ignore-pattern tests/api-testing .",
		"lint:scripts:tests": "eslint --cache --no-ignore --config tests/api-testing/.eslintrc.json tests/api-testing",
		"lint:styles": "stylelint --cache '**/*.{css,less}'",
		"test": "npm run lint && jest"
	},
	"devDependencies": {
		"api-testing": "1.7.3",
		"babel-jest": "29.7.0",
		"chai-openapi-response-validator": "^0.14.2",
		"eslint-config-wikimedia": "0.32.4",
		"grunt-banana-checker": "0.13.0",
		"jest": "29.7.0",
		"jest-environment-jsdom": "30.4.1",
		"stylelint-config-wikimedia": "0.19.2"
	}
}

{
	"name": "WikimediaCustomizations",
	"author": [
		"Gergő Tisza"
	],
	"url": "https://www.mediawiki.org/wiki/Special:MyLanguage/Extension:WikimediaCustomizations",
	"descriptionmsg": "wikimediacustomizations-desc",
	"license-name": "GPL-2.0-or-later",
	"type": "other",
	"requires": {
		"MediaWiki": ">= 1.47.0"
	},
	"attributes": {
		"GlobalPreferences": {
			"AutoPrefs": [
				"wikimedia-donor"
			]
		}
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\WikimediaCustomizations\\": "src/"
	},
	"ServiceWiringFiles": [
		"src/ServiceWiring.php"
	],
	"ConfigRegistry": {
		"WikimediaCustomizations": "MediaWiki\\Config\\GlobalVarConfig::newInstance"
	},
	"config": {
		"WMCBadEmailDomainsFile": {
			"description": "Path to the file listing the banned domains, one domain name per line.",
			"value": false
		},
		"WMCEmailAuthEnforce": {
			"description": "Whether to enforce email auth verification. Default is false, so log-only mode.",
			"value": false
		},
		"WMCPrivilegedGroups": {
			"description": "List of local groups which should be considered privileged. This is used for some security checks, mainly logging.",
			"value": []
		},
		"WMCPrivilegedGlobalGroups": {
			"description": "List of global groups which should be considered privileged. This is used for some security checks, mainly logging.",
			"value": []
		},
		"WMCPrivilegedPasswordPolicy": {
			"description": "Password policy applying to users in privileged groups.",
			"value": {}
		},
		"WMCGlobalGroupToRateLimitClass": {
			"description": "Map of global group names to the rate limit class ('rlc') assigned to members of that group in JWTs.",
			"value": {}
		},
		"WMCAttributionBrandmarkUrl": {
			"description": "URL to the site's brand sound",
			"value": "https://upload.wikimedia.org/wikipedia/commons/9/91/Wikimedia_Sonic_Logo_-_4-seconds.wav"
		},
		"WMCDiscord": {
			"description": "Configuration for the Discord preview generation service. Includes the base URL for the service, the name of the meta tag to use when adding preview URLs to pages, and the wprov value to use for analytics.",
			"value": {
				"baseUrl": null,
				"metaTagName": null,
				"wprov": null
			}
		}
	},
	"DefaultUserOptions": {
		"wikimedia-donor": "{ \"value\": 0 }"
	},
	"HookHandlers": {
		"discord": {
			"class": "MediaWiki\\Extension\\WikimediaCustomizations\\Discord\\DiscordHookHandler",
			"services": [
				"WikimediaCustomizations.Config"
			]
		},
		"bademaildomain": {
			"class": "MediaWiki\\Extension\\WikimediaCustomizations\\BadEmailDomain\\BadEmailDomainHookHandler",
			"services": [
				"WikimediaCustomizations.BadEmailDomainChecker"
			]
		},
		"donoridentification": {
			"class": "MediaWiki\\Extension\\WikimediaCustomizations\\DonorIdentification\\DonorIdentificationHookHandler",
			"services": []
		},
		"emailauth": {
			"class": "MediaWiki\\Extension\\WikimediaCustomizations\\EmailAuth\\EmailAuthHookHandler",
			"factory": "MediaWiki\\Extension\\WikimediaCustomizations\\EmailAuth\\EmailAuthHookHandler::factory"
		},
		"privilegedgroups-noservices": {
			"class": "MediaWiki\\Extension\\WikimediaCustomizations\\PrivilegedGroups\\PrivilegedGroupsNoServicesHookHandler"
		},
		"privilegedgroups": {
			"class": "MediaWiki\\Extension\\WikimediaCustomizations\\PrivilegedGroups\\PrivilegedGroupsHookHandler",
			"services": [
				"WikimediaCustomizations.Config",
				"WikimediaCustomizations.PrivilegedGroups"
			]
		},
		"ratelimit": {
			"class": "MediaWiki\\Extension\\WikimediaCustomizations\\RateLimit\\RateLimitHookHandler",
			"services": [
				"WikimediaCustomizations.Config",
				"ExtensionRegistry"
			]
		},
		"officeban": {
			"class": "MediaWiki\\Extension\\WikimediaCustomizations\\OfficeBan\\OfficeBanHookHandler",
			"services": [
				"ExtensionRegistry"
			]
		},
		"forcereauth": {
			"class": "MediaWiki\\Extension\\WikimediaCustomizations\\ForceReauth\\ForceReauthHookHandler",
			"services": [
				"AuthManager",
				"PermissionManager"
			]
		}
	},
	"Hooks": {
		"GetPreferences": "donoridentification",
		"UserCanChangeEmail": "bademaildomain",
		"EmailAuthRequireToken": "emailauth",
		"MediaWikiServices": "privilegedgroups-noservices",
		"GetSecurityLogContext": "privilegedgroups",
		"PasswordPoliciesForUser": "privilegedgroups",
		"GetSessionJwtData": "ratelimit",
		"BeforePageDisplay": [ "officeban", "discord" ],
		"getUserPermissionsErrorsExpensive": "forcereauth",
		"AlternateEdit": "forcereauth"
	},
	"ResourceFileModulePaths": {
		"localBasePath": "modules",
		"remoteExtPath": "WikimediaCustomizations/modules"
	},
	"ResourceModules": {
		"ext.wikimediaCustomizations.donor": {
			"dependencies": [
				"mediawiki.cookie"
			],
			"packageFiles": [
				"DonorIdentification/ext.wikimediaCustomizations.donor/index.js"
			]
		},
		"ext.wikimediaCustomizations.officeBan": {
			"scripts": [
				"OfficeBan/office-ban.js"
			],
			"dependencies": [
				"mediawiki.api",
				"mediawiki.ForeignApi",
				"codex-styles"
			]
		}
	},
	"AuthManagerAutoConfig": {
		"preauth": {
			"BadEmailDomainPreAuthenticationProvider": {
				"class": "MediaWiki\\Extension\\WikimediaCustomizations\\BadEmailDomain\\BadEmailDomainPreAuthenticationProvider",
				"sort": 0,
				"services": [
					"WikimediaCustomizations.BadEmailDomainChecker"
				]
			}
		}
	},
	"MessagesDirs": {
		"WikimediaCustomizations": [
			"i18n",
			"i18n/attribution"
		]
	},
	"RestModuleFiles": [
		"src/Attribution/attribution.v0-beta.json"
	],
	"manifest_version": 2
}
